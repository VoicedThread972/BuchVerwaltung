@model BuchVerwaltung.Web.Models.BuecherViewModel
@{
    ViewData["Title"] = "Buchverwaltung";
}

<h1 class="mb-1">Buchverwaltung</h1>
<p class="text-muted">
    Beide Bestände werden parallel geladen. Über die Schaltflächen lässt sich
    ein Buch in den jeweils anderen Bestand verschieben.
</p>

<div class="row g-4 mt-1">
    @* Linke Spalte: aktueller Bestand *@
    <div class="col-md-6">
        <div class="card shadow-sm">
            <div class="card-header bg-primary text-white fw-bold">
                Aktuelle Bücher (@Model.AktuelleBuecher.Count)
            </div>
            <div class="card-body p-0">
                <table class="table table-striped table-hover align-middle mb-0">
                    <thead>
                        <tr>
                            <th scope="col">Titel</th>
                            <th scope="col">Autor</th>
                            <th scope="col" class="text-end">Aktion</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var buch in Model.AktuelleBuecher)
                        {
                            <tr>
                                <td>@buch.Titel</td>
                                <td>@buch.Autor</td>
                                <td class="text-end">
                                    <form asp-action="InsArchiv" method="post" class="d-inline">
                                        <input type="hidden" name="id" value="@buch.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-primary">
                                            Ins Archiv &rarr;
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                        @if (Model.AktuelleBuecher.Count == 0)
                        {
                            <tr>
                                <td colspan="3" class="text-center text-muted py-3">
                                    Keine Bücher im aktuellen Bestand.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    @* Rechte Spalte: Archiv *@
    <div class="col-md-6">
        <div class="card shadow-sm">
            <div class="card-header bg-secondary text-white fw-bold">
                Archivierte Bücher (@Model.ArchivierteBuecher.Count)
            </div>
            <div class="card-body p-0">
                <table class="table table-striped table-hover align-middle mb-0">
                    <thead>
                        <tr>
                            <th scope="col" class="text-start">Aktion</th>
                            <th scope="col">Titel</th>
                            <th scope="col">Autor</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var buch in Model.ArchivierteBuecher)
                        {
                            <tr>
                                <td class="text-start">
                                    <form asp-action="InsAktuell" method="post" class="d-inline">
                                        <input type="hidden" name="id" value="@buch.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-secondary">
                                            &larr; Aktivieren
                                        </button>
                                    </form>
                                </td>
                                <td>@buch.Titel</td>
                                <td>@buch.Autor</td>
                            </tr>
                        }
                        @if (Model.ArchivierteBuecher.Count == 0)
                        {
                            <tr>
                                <td colspan="3" class="text-center text-muted py-3">
                                    Keine archivierten Bücher.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
